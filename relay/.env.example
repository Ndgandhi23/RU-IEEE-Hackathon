PORT=4000
PUBLIC_BASE_URL=http://192.168.1.167:4000

# Use a pre-generated Apple Maps token if you already have one.
APPLE_MAPS_SERVER_TOKEN=

# Or generate a token at runtime from your Apple Developer credentials.
APPLE_MAPS_TEAM_ID=
APPLE_MAPS_KEY_ID=
APPLE_MAPS_PRIVATE_KEY_PATH=
APPLE_MAPS_PRIVATE_KEY=
APPLE_MAPS_TOKEN_ORIGIN=

# Route fetch tuning
APPLE_MAPS_TRANSPORT_TYPE=WALKING
APPLE_MAPS_TOKEN_URL=https://maps-api.apple.com/v1/token
APPLE_MAPS_DIRECTIONS_URL=https://maps-api.apple.com/v1/directions
APPLE_MAPS_ROUTE_CACHE_TTL_MS=15000
APPLE_MAPS_ROUTE_CACHE_DISTANCE_METERS=5
