# Robot console — point at your laptop running the relay (same LAN IP everywhere).
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.167:4000

# Optional override for the Pi motor WebSocket.
# If you omit this line, the app uses ws://<relay-hostname>:8765 automatically
# (same machine as the relay — matches `python -m pi.motor_controller --mock`).
# Set this only when motors run on a different host than the relay, e.g.:
# EXPO_PUBLIC_PI_WS_URL=ws://192.168.1.50:8765
#
# After editing, restart `npx expo start`.
